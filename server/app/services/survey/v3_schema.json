          "options": [
            {"value": "none", "label": "없음"},
            {"value": "some", "label": "좀"},
            {"value": "lots", "label": "많이"}
          ],
          "show_if_sum": {"question_ids": ["C-12-1", "C-12-2"], "op": ">=", "value": 4}
        },
        {
          "id": "C-13-1",
          "text": "담배를 피운 적이 있나요?",
          "type": "single_select",
          "options": [
            {"value": "none", "label": "없음"},
            {"value": "tried", "label": "시도해봤음"},
            {"value": "occasional", "label": "가끔"},
            {"value": "regular", "label": "정기적"}
          ],
          "ksads_ref": "p.43"
        },
        {
          "id": "C-13-2",
          "text": "술을 마신 적이 있나요?",
          "type": "single_select",
