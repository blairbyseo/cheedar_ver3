          "show_if": {"question_id": "C-5-1", "op": "==", "value": "yes"}
        },
        {
          "id": "C-5-3",
          "text": "또 그럴까봐 걱정되나요?",
          "type": "single_select",
          "options": [
            {"value": "no", "label": "안 돼요"},
            {"value": "some", "label": "좀 돼요"},
            {"value": "lots", "label": "많이 돼요"}
