{
  "version": "v3",
  "name": "Cheddar 사전 설문 v3",
  "description": "BMI + Tier1~3 (K-SADS-PL 차용) + 보조축 + 개인화 분기. 약 10–12분 소요.",
  "estimated_minutes": 12,
  "scoring_module": "v3",
  "question_types": {
    "numeric": "숫자 입력 (unit, min, max, integer 선택)",
    "single_select": "단일 선택 (options[])",
    "multi_select": "다중 선택 (options[])",
    "scale_0_10": "0–10 슬라이더 (labels 선택)",
    "likert_0_3": "0/1/2/3 (0=없음 1=가끔 2=자주 3=거의매일 디폴트, labels로 오버라이드 가능)",
    "yes_no": "예/아니오",
    "free_text": "자유 서술 (max_length)",
    "time": "HH:MM",
    "composite": "여러 sub-field 묶음 (fields[])",
    "bmi": "키+몸무게+자동 BMI percentile (성장 차트 기반)",
    "checklist_with_frequency": "체크 + 빈도 (rows[], frequency_unit=days_per_week 디폴트)"
  },
  "branching_dsl": {
    "show_if": "{question_id, op, value} — op ∈ ==, !=, <, <=, >, >=, in, contains",
    "show_if_all": "[조건...] (AND)",
    "show_if_any": "[조건...] (OR)",
    "show_if_sum": "{question_ids: [...], op, value} — 합산 비교"
  },
  "sections": [
    {
      "id": "A",
      "title": "기본 정보",
      "description": "가장 사적이지 않은 항목부터. 입력 거부감 없이 시작.",
      "questions": [
        {
          "id": "A-1",
          "text": "나이가 어떻게 되나요?",
          "type": "numeric",
          "unit": "세",
          "integer": true,
          "min": 5,
          "max": 25,
          "prefill_from": "user.age",
          "skippable_if_prefilled": true
        },
        {
          "id": "A-2",
          "text": "성별이 어떻게 되나요?",
          "type": "single_select",
          "options": [
            {"value": "male", "label": "남"},
            {"value": "female", "label": "여"},
            {"value": "no_answer", "label": "응답 안 함"}
          ],
          "prefill_from": "user.gender",
          "skippable_if_prefilled": true
        },
        {
          "id": "A-3",
          "text": "지금 같이 사는 가족은 누구인가요? (해당하는 것 모두 체크해 주세요)",
          "type": "multi_select",
          "options": [
            {"value": "mother", "label": "엄마"},
            {"value": "father", "label": "아빠"},
            {"value": "sibling", "label": "형제자매"},
            {"value": "grandparent", "label": "조부모"},
            {"value": "other", "label": "기타"}
          ]
        },
        {
          "id": "A-4",
          "text": "학교를 다니고 있나요?",
          "type": "single_select",
          "options": [
            {"value": "enrolled", "label": "다니는 중"},
            {"value": "leave_dropout", "label": "휴학·자퇴"},
            {"value": "ged", "label": "검정고시"},
            {"value": "other", "label": "기타"}
          ]
        },
        {
          "id": "A-5",
          "text": "학원·과외는 주에 몇 시간 정도 하나요?",
          "type": "single_select",
          "options": [
            {"value": "0", "label": "0"},
            {"value": "1_5", "label": "1–5"},
            {"value": "6_10", "label": "6–10"},
            {"value": "11_20", "label": "11–20"},
            {"value": "20_plus", "label": "20시간 이상"}
          ]
        },
        {
          "id": "A-6",
          "text": "하루에 평균 몇 시간 정도 앉아 있나요? (학교·학원·공부·게임 다 포함)",
          "type": "numeric",
          "unit": "시간",
          "min": 0,
          "max": 24
        },
        {
          "id": "A-7",
          "text": "평소 몇 시쯤 자고 몇 시쯤 일어나나요?",
          "type": "composite",
          "fields": [
            {"id": "sleep_time", "type": "time", "label": "취침"},
            {"id": "wake_time", "type": "time", "label": "기상"}
          ]
        },
        {
          "id": "A-8",
          "text": "운동(체육 수업 제외)을 일주일에 몇 번 하나요?",
          "type": "single_select",
          "options": [
            {"value": "0", "label": "0"},
            {"value": "1_2", "label": "1–2"},
            {"value": "3_4", "label": "3–4"},
            {"value": "5_plus", "label": "5번 이상"}
          ]
        },
        {
          "id": "A-9",
          "text": "학교에서 시험을 보면 보통 평균 몇 점쯤 나오나요?",
          "type": "single_select",
          "options": [
            {"value": "95_plus", "label": "95+"},
            {"value": "85_94", "label": "85–94"},
            {"value": "75_84", "label": "75–84"},
            {"value": "65_74", "label": "65–74"},
            {"value": "below_65", "label": "65 미만"},
            {"value": "no_exam", "label": "시험 안 봄"}
          ],
          "note": "지능검사 대용 proxy"
        },
        {
          "id": "A-10",
          "text": "지금 본인의 건강 상태를 점수로 매긴다면 0–10점 중 몇 점인가요?",
          "type": "scale_0_10",
          "note": "self-rated health (한국 소아청소년 비만 임상진료지침)"
        }
      ]
    },
    {
      "id": "B",
      "title": "Tier 1 — BMI + 변화 동기",
      "description": "최상위 게이트.",
      "questions": [
        {
          "id": "B-1",
          "text": "키와 몸무게를 알려 주세요 (BMI는 자동으로 계산할게요)",
          "type": "bmi",
          "fields": [
            {"id": "height", "label": "키", "unit": "cm"},
            {"id": "weight", "label": "몸무게", "unit": "kg"}
          ],
          "prefill_from": "user.height_weight",
          "skippable_if_prefilled": true,
          "computes": ["bmi", "bmi_percentile", "bmi_category"]
        },
        {
          "id": "B-1b-1",
          "text": "지금 본인의 체중이나 체형에 대해 얼마나 만족하나요?",
          "type": "scale_0_10",
          "labels": {"0": "매우 불만족", "10": "매우 만족"}
        },
        {
          "id": "B-1b-2",
          "text": "어떤 부분이 가장 불만족스러운가요?",
          "type": "single_select",
          "options": [
            {"value": "weight", "label": "체중"},
            {"value": "part", "label": "특정 부위(배·허벅지·얼굴 등)"},
            {"value": "overall_shape", "label": "전체적인 체형"},
            {"value": "other", "label": "기타"}
          ],
          "allow_other_free_text": true,
          "show_if": {"question_id": "B-1b-1", "op": "<=", "value": 7}
        },
        {
          "id": "B-1b-3",
          "text": "체형이나 외모 때문에 다른 사람들의 시선이나 평가가 걱정된 적 있나요?",
          "type": "yes_no"
        },
        {
          "id": "B-1b-4",
          "text": "어떤 부분이 걱정되나요?",
          "type": "free_text",
          "max_length": 50,
          "show_if": {"question_id": "B-1b-3", "op": "==", "value": "yes"}
        },
        {
          "id": "B-2-1",
          "text": "Cheddar로 식습관·생활을 바꾸는 게 본인한테 얼마나 중요한가요?",
          "type": "scale_0_10",
          "labels": {"0": "전혀", "10": "엄청"}
        },
        {
          "id": "B-2-2",
          "text": "식습관·생활을 바꾸는 데 자신이 얼마나 있나요?",
          "type": "scale_0_10",
          "labels": {"0": "전혀", "10": "매우"}
        },
        {
          "id": "B-2-3",
          "text": "식습관이나 생활을 바꾸고 싶은 마음이 얼마나 있나요?",
          "type": "scale_0_10",
          "labels": {"0": "전혀", "10": "엄청"}
        },
        {
          "id": "B-2-4",
          "text": "그렇게 답한 가장 큰 이유가 무엇인가요?",
          "type": "single_select",
          "options": [
            {"value": "family_worry", "label": "가족이 걱정해서"},
            {"value": "body_mood", "label": "내 몸·기분이 좋아졌으면 해서"},
            {"value": "doctor_recommend", "label": "의사 선생님이 권해서"},
            {"value": "friends", "label": "친구 관계 때문에"},
            {"value": "unknown", "label": "잘 모르겠어요"}
          ]
        }
      ]
    },
    {
      "id": "C",
      "title": "Tier 2 — 동반 정신병리",
      "description": "K-SADS-PL 선별면담 차용. 응답은 0–3 (없음/가끔/자주/거의매일).",
      "questions": [
        {
          "id": "C-1-1",
          "text": "지난 2주 동안, 무엇을 해도 재미가 없거나 하고 싶지 않은 적이 얼마나 자주 있었나요?",
          "type": "likert_0_3",
          "ksads_ref": "p.7",
          "tag": "PHQ-2"
        },
        {
          "id": "C-1-2",
          "text": "지난 2주 동안, 기분이 가라앉거나, 우울하거나, 희망이 없다고 느낀 적이 얼마나 자주 있었나요?",
          "type": "likert_0_3",
          "ksads_ref": "p.7",
          "tag": "PHQ-2"
        },
        {
          "id": "C-2-1",
          "text": "지난 몇 주 동안, '차라리 죽었으면 좋겠다'는 생각이 든 적 있나요?",
          "type": "yes_no",
          "ksads_ref": "p.10",
          "tag": "suicide"
        },
        {
          "id": "C-2-2",
          "text": "지난 한 주 동안, 스스로를 다치게 하거나 죽고 싶다는 생각이 든 적 있나요?",
          "type": "yes_no",
          "ksads_ref": "p.10",
          "tag": "suicide"
        },
        {
          "id": "C-2-3",
          "text": "지금 이 순간에도 그런 생각이 드나요?",
          "type": "yes_no",
          "ksads_ref": "p.10",
          "tag": "suicide_acute",
          "show_if_any": [
            {"question_id": "C-2-1", "op": "==", "value": "yes"},
            {"question_id": "C-2-2", "op": "==", "value": "yes"}
          ]
        },
        {
          "id": "C-3-1",
          "text": "며칠 동안 평소보다 훨씬 들떠 있거나, 잠을 안 자도 멀쩡하거나, 갑자기 생각·행동이 빨라진 적이 있나요?",
          "type": "yes_no",
          "ksads_ref": "p.12",
          "tag": "mania"
        },
        {
          "id": "C-3-2",
          "text": "그게 며칠 이상 계속됐나요?",
          "type": "single_select",
          "options": [
            {"value": "1_3", "label": "1–3일"},
            {"value": "4_plus", "label": "4일 이상"},
            {"value": "1_week_plus", "label": "1주 이상"}
          ],
          "show_if": {"question_id": "C-3-1", "op": "==", "value": "yes"}
        },
        {
          "id": "C-4-1",
          "text": "다른 사람들에게는 들리지 않는 소리가 들리거나, 보이지 않는 것이 보인 적이 있나요?",
          "type": "yes_no",
          "ksads_ref": "p.14",
          "tag": "psychosis"
        },
        {
          "id": "C-4-2",
          "text": "한 번이었나요, 여러 번이었나요?",
          "type": "single_select",
          "options": [
            {"value": "once", "label": "한 번"},
            {"value": "multiple", "label": "여러 번"}
          ],
          "show_if": {"question_id": "C-4-1", "op": "==", "value": "yes"}
        },
        {
          "id": "C-4-3",
          "text": "잠들기 직전이었나요?",
          "type": "yes_no",
          "show_if": {"question_id": "C-4-1", "op": "==", "value": "yes"},
          "note": "입면기 환각 배제용"
        },
        {
          "id": "C-5-1",
          "text": "갑자기 가슴이 빠르게 뛰고 숨이 막히는 느낌이 든 적이 있나요?",
          "type": "yes_no",
          "ksads_ref": "p.16",
          "tag": "panic"
        },
        {
          "id": "C-5-2",
          "text": "얼마나 자주 그러나요?",
          "type": "single_select",
          "options": [
            {"value": "almost_daily", "label": "거의 매일"},
            {"value": "weekly", "label": "주 몇 번"},
            {"value": "occasional", "label": "가끔"}
