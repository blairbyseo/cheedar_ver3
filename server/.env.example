# =========================================================
# Cheddar Backend — 환경변수 템플릿
# 운영(.env)에서는 RDS + 실제 Kakao/OpenAI 키 사용,
# 로컬 개발에서는 Docker Postgres + 로컬 Kakao redirect 사용.
# =========================================================

# --- Database -----------------------------------------------------------
# 로컬 개발 (docker compose up -d):
DATABASE_URL=postgresql+psycopg://cheddar:cheddar_dev@localhost:5432/cheddar
# 운영 (예시): postgresql://postgres:<password>@<rds-host>:5432/cheddar_db?sslmode=require

# --- JWT / 쿠키 ---------------------------------------------------------
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 쿠키 보안 옵션 (운영 https에서는 true, 로컬은 false)
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# --- CORS ---------------------------------------------------------------
# 쉼표 구분. 운영 도메인 + 로컬 dev 포트 둘 다 등록.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000,https://cheddar-care.com,https://admin.cheddar-care.com

# --- File uploads -------------------------------------------------------
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10

# --- Kakao OAuth --------------------------------------------------------
# https://developers.kakao.com — 내 애플리케이션 > 앱 키 > REST API 키
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
# Kakao Developer Console에 등록한 redirect URI와 정확히 같아야 함
KAKAO_REDIRECT_URI=http://localhost:3000/oauth/kakao/callback

# --- OpenAI -------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# true면 OpenAI 호출 없이 고정 mock 응답 (개발용)
AI_MOCK_MODE=false

# --- Dev only ---------------------------------------------------------
# true면 /api/auth/dev-login (카카오 우회 로그인) 사용 가능. 운영 환경은 반드시 false.
ALLOW_DEV_LOGIN=false
